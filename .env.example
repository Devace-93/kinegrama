# Example environment for kinegrama.
# Copy to `.env` for local overrides; `.env` is gitignored and is where
# real secrets belong — never commit them here.

# Public site URL used for canonical/og meta tags and share links.
VITE_SITE_URL=https://kinegram.3m4.net

# URL of the 3m4 apps index site, linked from the footer.
VITE_INFO_URL=https://info.3m4.net

# Example secret (commented out; set real values only in .env):
#SOME_API_KEY=fake-api-key-123
